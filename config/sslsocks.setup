#!/bin/bash

case "$1" in
	"start")
	echo "start"
	nft -f /etc/ssl-socks/nftables.conf
	ip rule add fwmark 1 table 100
	ip route add local default table 100 dev lo
	ip -6 rule add fwmark 2 table 101
	ip -6 route add local default table 101 dev lo

	;;
	"stop")
	echo "stop"
	nft flush ruleset
	ip route del local default table 100
	ip rule del fwmark 1
	ip -6 route del local default table 101
	ip -6 rule del fwmark
	;;
esac
